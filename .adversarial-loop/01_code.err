   491	void decode_core_set_config_rsp(unsigned char* payload, int payload_len) {
   492	    printf("    CORE_SET_CONFIG_RSP - Set Configuration Response\n");
   493	
   494	    if (payload_len < 2) {
   495	        printf("      ERROR: Payload too short (%d bytes, need at least 2)\n", payload_len);
   496	        return;
   497	    }
   498	
   499	    unsigned char status = payload[0];
   500	    unsigned char num_configs = payload[1];
   501	
   502	    uci_print_status_line("Status", status);
   503	
   504	    printf("      Number of Config Status: %d\n", num_configs);
   505	
   506	    if (num_configs > 0 && payload_len >= 2) {
   507	        int offset = 2;
   508	        for (int i = 0; i < num_configs && offset + 2 <= payload_len; i++) {
   509	            DeviceConfigId cfg_id = (DeviceConfigId)payload[offset];
   510	            unsigned char cfg_status = payload[offset + 1];
   511	            offset += 2;
   512	
   513	            printf("      Config %d:\n", i);
   514	            printf("        Config ID: 0x%02X", cfg_id);
   515	            switch (cfg_id) {
   516	                case DEVICE_STATE: printf(" (DEVICE_STATE)\n"); break;
   517	                case LOW_POWER_MODE: printf(" (LOW_POWER_MODE)\n"); break;
   518	                default: printf(" (UNKNOWN)\n"); break;
   519	            }
   520	
   521	            uci_print_status_line("Status", cfg_status);
   522	        }
   523	    }
   524	}
   525	
   526	void decode_core_get_config_rsp(unsigned char* payload, int payload_len) {
   527	    printf("    CORE_GET_CONFIG_RSP - Get Configuration Response\n");
   528	
   529	    if (payload_len < 2) {
   530	        printf("      ERROR: Payload too short (%d bytes, need at least 2)\n", payload_len);
   531	        return;
   532	    }
   533	
   534	    unsigned char status = payload[0];
   535	    unsigned char num_tlvs = payload[1];
   536	
   537	    uci_print_status_line("Status", status);
   538	
   539	    printf("      Number of TLVs: %d\n", num_tlvs);
   540	
   541	    if (num_tlvs > 0 && payload_len >= 2) {
   542	        int offset = 2;
   543	        for (int i = 0; i < num_tlvs && offset + 3 <= payload_len; i++) {
   544	            DeviceConfigId cfg_id = (DeviceConfigId)payload[offset];
   545	            unsigned char cfg_len = payload[offset + 1];
   546	            offset += 2;
   547	
   548	            printf("      TLV %d:\n", i);
   549	            printf("        Config ID: 0x%02X", cfg_id);
   550	            switch (cfg_id) {
   551	                case DEVICE_STATE: printf(" (DEVICE_STATE)\n"); break;
   552	                case LOW_POWER_MODE: printf(" (LOW_POWER_MODE)\n"); break;
   553	                default: printf(" (UNKNOWN)\n"); break;
   554	            }
   555	
   556	            printf("        Length: %d\n", cfg_len);
   557	
   558	            if (offset + cfg_len <= payload_len) {
   559	                printf("        Value: ");
   560	                for (int j = 0; j < cfg_len; j++) {
   561	                    printf("%02X ", payload[offset + j]);
   562	                }
   563	                printf("\n");
   564	
   565	                if (cfg_id == DEVICE_STATE && cfg_len == 1) {
   566	                    uci_print_device_state_line("Interpreted as Device State", payload[offset]);
   567	                } else if (cfg_id == LOW_POWER_MODE && cfg_len == 1) {
   568	                    unsigned char lpm = payload[offset];
   569	                    printf("          Interpreted as Low Power Mode: %s (0x%02X)\n",
   570	                           lpm ? "ON" : "OFF", lpm);
   571	                }
   572	            } else {
   573	                printf("        Value: TRUNCATED (expected %d bytes, only %d available)\n", cfg_len, payload_len - offset);
   574	            }
   575	
   576	            offset += cfg_len;
   577	        }
   578	    }
   579	}
