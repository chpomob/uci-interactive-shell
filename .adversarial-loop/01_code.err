-                for (int j = 0; j < cfg_len && j < 8; j++) {
-                    value |= ((uint64_t)payload[offset + 2 + j]) << (j * 8);
-                }
-                
-                // Get parameter range information
-                uint64_t min_val, max_val;
-                if (uci_config_get_app_param_range((AppConfigTlvType)cfg_id, &min_val, &max_val) == 0) {
-                    if (ui_color_enabled) {
