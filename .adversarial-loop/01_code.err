  3243	            case UCI_STATUS_REJECTED: printf(" (REJECTED)\n"); break;
  3244	            case UCI_STATUS_FAILED: printf(" (FAILED)\n"); break;
  3245	            case UCI_STATUS_INVALID_PARAM: printf(" (INVALID_PARAM)\n"); break;
  3246	            default: printf(" (UNKNOWN)\n"); break;
  3247	        }
  3248	        // Call enhanced analysis for more detailed information
