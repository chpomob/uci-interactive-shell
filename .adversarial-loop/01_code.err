-                    switch(value) {
-                        case 0: printf("NO_AOA_REPORT (0x%02X)\n", value); break;
-                        case 1: printf("AOA_ELEVATION (0x%02X)\n", value); break;
-                        case 2: printf("AOA_AZIMUTH (0x%02X)\n", value); break;
