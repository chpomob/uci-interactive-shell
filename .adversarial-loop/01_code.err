-
-    if (payload_len > 8) {
-        printf("      Additional Data (%d bytes): ", payload_len - 8);
-        for (int i = 8; i < payload_len; i++) {
-            printf("%02X ", payload[i]);
         }
         printf("\n");
-    }
-}
