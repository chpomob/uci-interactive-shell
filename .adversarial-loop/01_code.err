    82	static void print_field_line_color(int indent,
    83	                                   const char* label,
    84	                                   const char* label_color,
    85	                                   const char* fmt,
    86	                                   ...) {
    87	    char value_buf[256];
    88	    va_list args;
    89	    va_start(args, fmt);
    90	    vsnprintf(value_buf, sizeof(value_buf), fmt, args);
    91	    va_end(args);
    92	
    93	    if (ui_color_enabled) {
    94	        const char* color = label_color ? label_color : ANSI_COLOR_BRIGHT_GREEN;
    95	        printf("%*s%s%s%s: %s%s\n",
    96	               indent,
    97	               "",
    98	               color,
    99	               ANSI_BOLD,
   100	               label,
   101	               ANSI_RESET,
   102	               value_buf);
   103	    } else {
   104	        printf("%*s%s: %s\n", indent, "", label, value_buf);
   105	    }
   106	}
   107	
   108	static void print_error_line(int indent, const char* fmt, ...) {
   109	    char value_buf[256];
   110	    va_list args;
   111	    va_start(args, fmt);
   112	    vsnprintf(value_buf, sizeof(value_buf), fmt, args);
   113	    va_end(args);
   114	
   115	    if (ui_color_enabled) {
   116	        printf("%*s%s%sError:%s %s\n",
   117	               indent,
   118	               "",
   119	               ANSI_COLOR_RED,
   120	               ANSI_BOLD,
   121	               ANSI_RESET,
   122	               value_buf);
   123	    } else {
   124	        printf("%*sError: %s\n", indent, "", value_buf);
   125	    }
   126	}
   127	
   128	static void print_warning_line(int indent, const char* fmt, ...) {
   129	    char value_buf[256];
   130	    va_list args;
   131	    va_start(args, fmt);
   132	    vsnprintf(value_buf, sizeof(value_buf), fmt, args);
   133	    va_end(args);
   134	
   135	    if (ui_color_enabled) {
   136	        printf("%*s%s%sWarning:%s %s\n",
   137	               indent,
   138	               "",
   139	               ANSI_COLOR_YELLOW,
   140	               ANSI_BOLD,
   141	               ANSI_RESET,
   142	               value_buf);
   143	    } else {
   144	        printf("%*sWarning: %s\n", indent, "", value_buf);
   145	    }
   146	}
   147	
   148	static void print_hex_data(int indent,
   149	                           const char* label,
   150	                           const unsigned char* data,
   151	                           int length,
   152	                           int max_bytes) {
   153	    if (length <= 0) {
   154	        print_field_line_color(indent, label, ANSI_COLOR_BRIGHT_BLACK, "(none)");
   155	        return;
   156	    }
   157	
   158	    char buffer[512];
   159	    int pos = 0;
   160	    int bytes_to_show = (max_bytes > 0 && length > max_bytes) ? max_bytes : length;
   161	
   162	    for (int i = 0; i < bytes_to_show; i++) {
   163	        if (pos >= (int)sizeof(buffer) - 4) {
   164	            break;
   165	        }
   166	        pos += snprintf(buffer + pos, sizeof(buffer) - (size_t)pos, "%02X%s",
   167	                        data[i], (i + 1 < bytes_to_show) ? " " : "");
   168	    }
   169	
   170	    if (bytes_to_show < length && pos < (int)sizeof(buffer) - 5) {
   171	        snprintf(buffer + pos, sizeof(buffer) - (size_t)pos, " ...");
   172	    }
   173	
   174	    print_field_line_color(indent, label, ANSI_COLOR_BRIGHT_BLACK, "%s", buffer);
   175	}
   176	
   177	
   178	static void ui_print_status_lookup_line_internal(const char* label,
   179	                                                 unsigned char status_code,
   180	                                                 int indent) {
   181	    const uci_lookup_entry_t* entry = uci_lookup_status(status_code);
   182	
   183	    const char* status_color = ANSI_COLOR_BRIGHT_YELLOW;
   184	    if (entry && entry->label) {
   185	        if (strncasecmp(entry->label, "OK", 2) == 0 || strstr(entry->label, "SUCCESS") != NULL) {
   186	            status_color = ANSI_COLOR_BRIGHT_GREEN;
   187	        } else if (strstr(entry->label, "ERROR") != NULL || strstr(entry->label, "FAILED") != NULL) {
   188	            status_color = ANSI_COLOR_RED;
   189	        } else if (strstr(entry->label, "RFU") != NULL || strstr(entry->label, "RESERVED") != NULL) {
   190	            status_color = ANSI_COLOR_BRIGHT_BLACK;
   191	        } else {
   192	            status_color = ANSI_COLOR_BRIGHT_CYAN;
   193	        }
   194	    } else if (status_code == UCI_STATUS_OK) {
   195	        status_color = ANSI_COLOR_BRIGHT_GREEN;
   196	    }
   197	
   198	    print_lookup_line_with_indent(indent, label, status_code, entry, status_color);
   199	}
