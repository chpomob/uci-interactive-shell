  3128	// Android vendor command response decoders
  3129	
  3130	// Decode ANDROID_GET_POWER_STATS response
  3131	void ui_decode_android_get_power_stats_rsp(const unsigned char* payload, int payload_len) {
  3132	    if (ui_color_enabled) {
  3133	        printf("  %s%sANDROID_GET_POWER_STATS Response:%s\n", ANSI_COLOR_BRIGHT_MAGENTA, ANSI_BOLD, ANSI_RESET);
  3134	    } else {
  3135	        printf("  ANDROID_GET_POWER_STATS Response:\n");
  3136	    }
  3137	
  3138	    if (payload_len < 17) {
  3139	        if (ui_color_enabled) {
  3140	            printf("    %s%sError: Payload too short (%d bytes, need at least 17)%s\n",
  3141	                   ANSI_COLOR_RED, ANSI_BOLD, payload_len, ANSI_RESET);
  3142	        } else {
  3143	            printf("    Error: Payload too short (%d bytes, need at least 17)\n", payload_len);
  3144	        }
  3145	        return;
  3146	    }
  3147	
  3148	    unsigned char status = payload[0];
  3149	
  3150	    if (ui_color_enabled) {
  3151	        printf("    %s%sStatus:%s 0x%02X", ANSI_COLOR_BRIGHT_YELLOW, ANSI_BOLD, ANSI_RESET, status);
  3152	        switch(status) {
  3153	            case UCI_STATUS_OK: printf(" %s(OK)%s\n", ANSI_COLOR_BRIGHT_GREEN, ANSI_RESET); break;
  3154	            case UCI_STATUS_REJECTED: printf(" %s(REJECTED)%s\n", ANSI_COLOR_RED, ANSI_RESET); break;
  3155	            case UCI_STATUS_FAILED: printf(" %s(FAILED)%s\n", ANSI_COLOR_RED, ANSI_RESET); break;
  3156	            case UCI_STATUS_INVALID_PARAM: printf(" %s(INVALID_PARAM)%s\n", ANSI_COLOR_RED, ANSI_RESET); break;
  3157	            default: printf(" %s(UNKNOWN)%s\n", ANSI_COLOR_YELLOW, ANSI_RESET); break;
  3158	        }
  3159	        // Call enhanced analysis for more detailed information
  3160	        if (status != UCI_STATUS_OK) {
  3161	            enhanced_error_analysis(status);
  3162	        }
  3163	        printf("    %s%sPower Statistics Data:%s %d bytes\n",
  3164	               ANSI_COLOR_BRIGHT_CYAN, ANSI_BOLD, ANSI_RESET, payload_len - 1);
  3165	    } else {
  3166	        printf("    Status: 0x%02X", status);
  3167	        switch(status) {
  3168	            case UCI_STATUS_OK: printf(" (OK)\n"); break;
  3169	            case UCI_STATUS_REJECTED: printf(" (REJECTED)\n"); break;
  3170	            case UCI_STATUS_FAILED: printf(" (FAILED)\n"); break;
  3171	            case UCI_STATUS_INVALID_PARAM: printf(" (INVALID_PARAM)\n"); break;
  3172	            default: printf(" (UNKNOWN)\n"); break;
  3173	        }
  3174	        // Call enhanced analysis for more detailed information
  3175	        if (status != UCI_STATUS_OK) {
  3176	            enhanced_error_analysis(status);
  3177	        }
  3178	        printf("    Power Statistics Data: %d bytes\n", payload_len - 1);
  3179	    }
  3180	
  3181	    // Display power statistics data in hex format
  3182	    if (payload_len > 1) {
  3183	        if (ui_color_enabled) {
  3184	            printf("    %s%sRaw Data:%s ", ANSI_COLOR_BRIGHT_WHITE, ANSI_BOLD, ANSI_RESET);
  3185	        } else {
  3186	            printf("    Raw Data: ");
  3187	        }
  3188	        for (int i = 1; i < payload_len && i < 33; i++) {
  3189	            if (ui_color_enabled) {
  3190	                printf("%s%02X%s ", ANSI_COLOR_BRIGHT_WHITE, payload[i], ANSI_RESET);
  3191	            } else {
  3192	                printf("%02X ", payload[i]);
  3193	            }
  3194	        }
  3195	        if (payload_len > 33) {
  3196	            if (ui_color_enabled) {
  3197	                printf("%s... (and %d more bytes)%s", ANSI_COLOR_BRIGHT_BLACK, payload_len - 33, ANSI_RESET);
  3198	            } else {
  3199	                printf("... (and %d more bytes)", payload_len - 33);
  3200	            }
  3201	        }
  3202	        printf("\n");
  3203	    }
  3204	}
