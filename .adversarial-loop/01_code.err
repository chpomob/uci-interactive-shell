-            AppConfigTlvType cfg_id = (AppConfigTlvType)payload[offset];
-            unsigned char cfg_len = payload[offset + 1];
-            const char* cfg_name = uci_config_get_app_param_name(cfg_id);
-            offset += 2;
-
-            printf("      TLV %d:\n", i);
-            printf("        Config ID: 0x%02X", cfg_id);
