diff --git a/src/uci_plain_decoders.c b/src/uci_plain_decoders.c
index d5ffd344f82b5f662af8002c0adb8fac4f6bb5ed..2860b9961f68c8f1646d4652e72b637e82cd1a6e
--- a/src/uci_plain_decoders.c
