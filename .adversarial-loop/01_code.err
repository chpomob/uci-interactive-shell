-    print_field_line_color(4,
-                           "Sequence Number",
-                           ANSI_COLOR_BRIGHT_YELLOW,
-                           "%u",
-                           sequence_number);
-    print_field_line_color(4,
-                           "Frame Report Count",
-                           ANSI_COLOR_BRIGHT_YELLOW,
-                           "%u",
-                           report_count);
-
-    for (uint8_t report_idx = 0; report_idx < report_count; ++report_idx) {
