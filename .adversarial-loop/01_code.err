-    if (payload_len < 6) {
-        printf("      ERROR: Payload too short (%d bytes, need at least 6)\n", payload_len);
-        return;
-    }
-
-    unsigned int session_token = read_u32_le(payload);
-    unsigned short uci_sequence_number = read_u16_le(&payload[4]);
