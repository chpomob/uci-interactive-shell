  1162	    if (payload_len < 1) {
  1163	        if (ui_color_enabled) {
  1164	            printf("    %s%sError: Payload too short (%d bytes, need at least 1)%s\n",
  1165	                   ANSI_COLOR_RED, ANSI_BOLD, payload_len, ANSI_RESET);
  2850	    if (ui_color_enabled) {
  2851	        printf("    %s%sSession Handle:%s 0x%08X\n", ANSI_COLOR_BRIGHT_GREEN, ANSI_BOLD, ANSI_RESET, session_handle);
  2852	        printf("    %s%sLogical Link ID:%s 0x%02X\n", ANSI_COLOR_BRIGHT_GREEN, ANSI_BOLD, ANSI_RESET, link_id);
  2853	        printf("    %s%sReason:%s 0x%02X\n", ANSI_COLOR_BRIGHT_GREEN, ANSI_BOLD, ANSI_RESET, reason);
  2854	    } else {
  2855	        printf("    Session Handle: 0x%08X\n", session_handle);
  2856	        printf("    Logical Link ID: 0x%02X\n", link_id);
  2857	        printf("    Reason: 0x%02X\n", reason);
  2858	    }
  2859	}
  2860	
  2861	
  2862	void ui_decode_android_range_diagnostics_ntf(const unsigned char* payload, int payload_len) {
  2863	    if (ui_color_enabled) {
  2864	        printf("  %s%sANDROID_RANGE_DIAGNOSTICS_NTF:%s\n", ANSI_COLOR_BRIGHT_MAGENTA, ANSI_BOLD, ANSI_RESET);
  2865	    } else {
  2866	        printf("  ANDROID_RANGE_DIAGNOSTICS_NTF:\n");
  2867	    }
  2868	
  2869	    if (payload_len < 9) {
  2870	        print_error_line(4, "Payload too short for diagnostics notification (%d bytes)", payload_len);
  2871	        return;
  2872	    }
  2873	
  2874	    uint32_t session_token = ui_read_u32_le(&payload[0]);
  2875	    uint32_t sequence_number = ui_read_u32_le(&payload[4]);
  2876	    uint8_t report_count = payload[8];
  2877	    int offset = 9;
  2878	
  2879	    print_field_line_color(4,
  2880	                           "Session Token",
  2881	                           ANSI_COLOR_BRIGHT_YELLOW,
  2882	                           "0x%08X",
  2883	                           session_token);
  2884	    print_field_line_color(4,
  2885	                           "Sequence Number",
  2886	                           ANSI_COLOR_BRIGHT_YELLOW,
  2887	                           "%u",
  2888	                           sequence_number);
  2889	    print_field_line_color(4,
  2890	                           "Frame Report Count",
  2891	                           ANSI_COLOR_BRIGHT_YELLOW,
  2892	                           "%u",
  2893	                           report_count);
  2894	
  2895	    for (uint8_t report_idx = 0; report_idx < report_count; ++report_idx) {
  2896	        if (offset + 4 > payload_len) {
  2897	            print_error_line(4, "Diagnostics report %u truncated", report_idx + 1);
  2898	            return;
  2899	        }
  2900	
  2901	        uint8_t msg_id = payload[offset++];
  2902	        uint8_t action = payload[offset++];
  2903	        uint8_t antenna_set = payload[offset++];
  2904	        uint8_t field_count = payload[offset++];
  2905	
  2906	        if (ui_color_enabled) {
  2907	            printf("    %s%sFrame Report %u:%s\n",
  2908	                   ANSI_COLOR_BRIGHT_CYAN,
  2909	                   ANSI_BOLD,
  2910	                   report_idx + 1,
  2911	                   ANSI_RESET);
  2912	        } else {
  2913	            printf("    Frame Report %u:\n", report_idx + 1);
  2914	        }
  2915	
  2916	        print_field_line_color(6,
  2917	                               "Message ID",
  2918	                               ANSI_COLOR_BRIGHT_GREEN,
  2919	                               "0x%02X",
  2920	                               msg_id);
  2921	        print_field_line_color(6,
  2922	                               "Action",
  2923	                               ANSI_COLOR_BRIGHT_GREEN,
  2924	                               "0x%02X",
  2925	                               action);
  2926	        print_field_line_color(6,
  2927	                               "Antenna Set",
  2928	                               ANSI_COLOR_BRIGHT_GREEN,
  2929	                               "0x%02X",
  2930	                               antenna_set);
  2931	        print_field_line_color(6,
  2932	                               "Field Count",
  2933	                               ANSI_COLOR_BRIGHT_GREEN,
  2934	                               "%u",
  2935	                               field_count);
  2936	
  2937	        for (uint8_t field_idx = 0; field_idx < field_count; ++field_idx) {
  2938	            if (offset + 3 > payload_len) {
  2939	                print_error_line(6,
  2940	                                 "Report %u field %u truncated",
  2941	                                 report_idx + 1,
  2942	                                 field_idx + 1);
  2943	                return;
  2944	            }
  2945	
  2946	            uint8_t field_id = payload[offset++];
  2947	            uint16_t field_size = ui_read_u16_le(&payload[offset]);
  2948	            offset += 2;
  2949	
  2950	            if (offset + field_size > payload_len) {
  2951	                print_error_line(6,
  2952	                                 "Report %u field %u exceeds payload",
  2953	                                 report_idx + 1,
  2954	                                 field_idx + 1);
  2955	                return;
  2956	            }
  2957	
  2958	            const unsigned char* field_data = &payload[offset];
  2959	            offset += field_size;
  2960	
  2961	            switch (field_id) {
  2962	                case UCI_DIAG_REPORT_AOAS: {
  2963	                    if (field_size % 8 != 0) {
  2964	                        print_warning_line(6, "AoA field has unexpected length %u", field_size);
  2965	                    }
  2966	                    uint16_t entry_count = field_size / 8;
  2967	                    print_field_line_color(6,
  2968	                                           "AoA Measurements",
  2969	                                           ANSI_COLOR_BRIGHT_GREEN,
  2970	                                           "%u entries",
  2971	                                           entry_count);
  2972	                    for (uint16_t idx = 0; idx < entry_count; ++idx) {
  2973	                        const unsigned char* entry = &field_data[idx * 8];
  2974	                        int16_t tdoa = (int16_t)ui_read_u16_le(&entry[0]);
  2975	                        int16_t pdoa = (int16_t)ui_read_u16_le(&entry[2]);
  2976	                        int16_t aoa = (int16_t)ui_read_u16_le(&entry[4]);
  2977	                        uint8_t fom = entry[6];
  2978	                        uint8_t type = entry[7];
  2979	                        print_field_line_color(8,
  2980	                                               "AoA Entry",
  2981	                                               ANSI_COLOR_BRIGHT_GREEN,
  2982	                                               "TDoA=%d, PDoA=%d, AoA=%d, FoM=%u, Type=0x%02X",
  2983	                                               tdoa,
  2984	                                               pdoa,
  2985	                                               aoa,
  2986	                                               fom,
  2987	                                               type);
  2988	                    }
  2989	                    break;
  2990	                }
  2991	                case UCI_DIAG_REPORT_EXTRA_STATUS: {
  2992	                    if (field_size >= 2) {
  2993	                        uint16_t extra = ui_read_u16_le(field_data);
  2994	                        print_field_line_color(6,
  2995	                                               "Extra Status",
  2996	                                               ANSI_COLOR_BRIGHT_GREEN,
  2997	                                               "0x%04X",
  2998	                                               extra);
  2999	                    } else {
  3000	                        print_warning_line(6, "Extra status too short (%u bytes)", field_size);
  3001	                    }
  3002	                    break;
  3003	                }
  3004	                case UCI_DIAG_REPORT_CFO_Q26: {
  3005	                    if (field_size >= 4) {
  3006	                        int32_t cfo_raw = (int32_t)ui_read_u32_le(field_data);
  3007	                        print_field_line_color(6,
  3008	                                               "CFO Q26",
  3009	                                               ANSI_COLOR_BRIGHT_GREEN,
  3010	                                               "%d",
  3011	                                               cfo_raw);
  3012	                    } else {
  3013	                        print_warning_line(6, "CFO Q26 too short (%u bytes)", field_size);
  3014	                    }
  3015	                    break;
  3016	                }
  3017	                case UCI_DIAG_REPORT_EMITTER_SHORT_ADDR: {
  3018	                    if (field_size >= 2) {
  3019	                        uint16_t short_addr = ui_read_u16_le(field_data);
  3020	                        print_field_line_color(6,
  3021	                                               "Emitter Short Address",
  3022	                                               ANSI_COLOR_BRIGHT_GREEN,
  3023	                                               "0x%04X",
  3024	                                               short_addr);
  3025	                    } else {
  3026	                        print_warning_line(6,
  3027	                                           "Emitter short address too short (%u bytes)",
  3028	                                           field_size);
  3029	                    }
  3030	                    break;
  3031	                }
  3032	                case UCI_DIAG_REPORT_SEGMENT_METRICS: {
  3033	                    if (field_size % 17 != 0) {
  3034	                        print_warning_line(6,
  3035	                                           "Segment metrics unexpected size %u",
  3036	                                           field_size);
  3037	                    }
  3038	                    uint16_t metric_count = field_size / 17;
  3039	                    print_field_line_color(6,
  3040	                                           "Segment Metrics",
  3041	                                           ANSI_COLOR_BRIGHT_GREEN,
  3042	                                           "%u entries",
  3043	                                           metric_count);
  3044	                    for (uint16_t idx = 0; idx < metric_count; ++idx) {
  3045	                        const unsigned char* entry = &field_data[idx * 17];
  3046	                        uint8_t receiver_segment = entry[0];
  3047	                        uint16_t noise_value = ui_read_u16_le(&entry[1]);
  3048	                        double rsl_q8 = decode_q_unsigned(ui_read_u16_le(&entry[3]), 8);
  3049	                        uint16_t fp_index = ui_read_u16_le(&entry[5]);
  3050	                        double fp_rsl = decode_q_unsigned(ui_read_u16_le(&entry[7]), 8);
  3051	                        double fp_ns = decode_q_unsigned(ui_read_u16_le(&entry[9]), 6);
  3052	                        uint16_t pp_index = ui_read_u16_le(&entry[11]);
  3053	                        double pp_rsl = decode_q_unsigned(ui_read_u16_le(&entry[13]), 8);
  3054	                        double pp_ns = decode_q_unsigned(ui_read_u16_le(&entry[15]), 6);
  3055	                        print_field_line_color(8,
  3056	                                               "Metric",
  3057	                                               ANSI_COLOR_BRIGHT_GREEN,
  3058	                                               "seg=%u noise=%u rsl=%.2f fp_idx=%u fp_rsl=%.2f fp_ns=%.2f pp_idx=%u pp_rsl=%.2f pp_ns=%.2f",
  3059	                                               receiver_segment,
  3060	                                               noise_value,
  3061	                                               rsl_q8,
  3062	                                               fp_index,
  3063	                                               fp_rsl,
  3064	                                               fp_ns,
  3065	                                               pp_index,
  3066	                                               pp_rsl,
  3067	                                               pp_ns);
  3068	                    }
  3069	                    break;
  3070	                }
  3071	                case UCI_DIAG_REPORT_CIRS: {
  3072	                    uint16_t remaining = field_size;
  3073	                    const unsigned char* cursor_ptr = field_data;
  3074	                    uint8_t cir_index = 0;
  3075	                    while (remaining >= 4) {
  3076	                        uint8_t receiver_segment = cursor_ptr[0];
  3077	                        uint8_t fpath_tap_offset = cursor_ptr[1];
  3078	                        uint8_t tap_count = cursor_ptr[2];
  3079	                        uint8_t tap_size = cursor_ptr[3];
  3080	                        cursor_ptr += 4;
  3081	                        remaining -= 4;
  3082	                        uint16_t taps_bytes = (uint16_t)tap_count * tap_size;
  3083	                        if (remaining < taps_bytes) {
  3084	                            print_warning_line(8,
  3085	                                               "CIR entry %u truncated",
  3086	                                               cir_index + 1);
  3087	                            break;
  3088	                        }
  3089	                        print_field_line_color(8,
  3090	                                               "CIR Entry",
  3091	                                               ANSI_COLOR_BRIGHT_GREEN,
  3092	                                               "seg=%u fp_offset=%u taps=%u size=%u",
  3093	                                               receiver_segment,
  3094	                                               fpath_tap_offset,
  3095	                                               tap_count,
  3096	                                               tap_size);
  3097	                        cursor_ptr += taps_bytes;
  3098	                        remaining -= taps_bytes;
  3099	                        cir_index++;
  3100	                    }
  3101	                    if (remaining > 0) {
  3102	                        print_hex_data(8, "CIR Residual", cursor_ptr, remaining, remaining);
  3103	                    }
  3104	                    break;
  3105	                }
  3106	                case UCI_DIAG_REPORT_CONFIDENCE_METRICS:
  3107	                case UCI_DIAG_REPORT_SEGMENT_CONFIDENCE_RAW_DATA:
  3108	                default:
  3109	                    print_hex_data(6,
  3110	                                   "Diagnostics Field",
  3111	                                   field_data,
  3112	                                   field_size,
  3113	                                   32);
  3114	                    break;
  3115	            }
  3116	        }
  3117	    }
  3118	
  3119	    if (offset < payload_len) {
  3120	        print_hex_data(4,
  3121	                       "Trailing Diagnostics Data",
  3122	                       &payload[offset],
  3123	                       payload_len - offset,
  3124	                       32);
  3125	    }
  3126	}
