-                        case 5: printf("Channel 5 (0x%02X)\n", value); break;
-                        case 9: printf("Channel 9 (0x%02X)\n", value); break;
-                        default: printf("UNKNOWN (0x%02X)\n", value); break;
-                    }
-                }
