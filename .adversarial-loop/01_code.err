   143	static void decode_frame_report_tlv(FrameReportTlvType tlv_type,
   144	                                    const unsigned char* value,
   145	                                    unsigned short length) {
   146	    const char* name = get_frame_report_tlv_name(tlv_type);
   147	    printf("        TLV Type: 0x%02X", tlv_type);
   148	    if (name) {
   149	        printf(" (%s)", name);
   150	    } else {
   151	        printf(" (UNKNOWN)");
   152	    }
   153	    printf(", Length: %u\n", length);
   154	
   155	    if (!value || length == 0) {
   156	        printf("          No data.\n");
   157	        return;
   158	    }
   159	
   160	    switch (tlv_type) {
   161	        case FRAME_REPORT_TLV_RSSI: {
   162	            printf("          RSSI Samples (dBm): ");
   163	            for (unsigned short i = 0; i < length; i++) {
   164	                printf("%d ", (int8_t)value[i]);
   165	            }
   166	            printf("\n");
   167	            break;
   168	        }
   169	        case FRAME_REPORT_TLV_AOA: {
   170	            if (length % 8 != 0) {
   171	                printf("          WARNING: AOA payload length %u is not a multiple of 8 bytes.\n", length);
   172	            }
   173	            unsigned short offset = 0;
   174	            unsigned int measurement_idx = 0;
   175	            while (offset + 8 <= length) {
   176	                int16_t tdoa = (int16_t)read_u16_le(&value[offset]);
   177	                int16_t pdoa = (int16_t)read_u16_le(&value[offset + 2]);
   178	                int16_t aoa = (int16_t)read_u16_le(&value[offset + 4]);
   179	                unsigned char fom = value[offset + 6];
   180	                unsigned char meas_type = value[offset + 7];
   181	                printf("          Measurement %u: TDOA=%d, PDOA=%d, AoA=%d, FoM=%u, Type=0x%02X\n",
   182	                       measurement_idx++, tdoa, pdoa, aoa, fom, meas_type);
   183	                offset += 8;
   184	            }
   185	            if (offset < length) {
   186	                printf("          %u trailing bytes remain unparsed.\n", (unsigned int)(length - offset));
   187	            }
   188	            break;
   189	        }
   190	        case FRAME_REPORT_TLV_CIR: {
   191	            unsigned short offset = 0;
   192	            if (length < 1) {
   193	                printf("          WARNING: CIR payload too short.\n");
   194	                break;
   195	            }
   196	            unsigned char cir_entries = value[offset++];
   197	            printf("          CIR Entries: %u\n", cir_entries);
   198	            for (unsigned char entry = 0; entry < cir_entries; entry++) {
   199	                if (offset + 16 > length) {
   200	                    printf("          WARNING: CIR entry %u truncated (need at least 16 bytes, have %u).\n",
   201	                           entry, (unsigned int)(length - offset));
   202	                    break;
   203	                }
   204	                unsigned short first_path_index = read_u16_le(&value[offset]);
   205	                unsigned short first_path_snr = read_u16_le(&value[offset + 2]);
   206	                unsigned short first_path_ns = read_u16_le(&value[offset + 4]);
   207	                unsigned short peak_path_index = read_u16_le(&value[offset + 6]);
   208	                unsigned short peak_path_snr = read_u16_le(&value[offset + 8]);
   209	                unsigned short peak_path_ns = read_u16_le(&value[offset + 10]);
   210	                unsigned char first_path_sample_offset = value[offset + 12];
   211	                unsigned char samples_number = value[offset + 13];
   212	                unsigned short sample_window_len = read_u16_le(&value[offset + 14]);
   213	                offset += 16;
   214	
   215	                printf("          CIR %u: first_path_index=%u, first_path_snr=%u, first_path_ns=%u\n",
   216	                       entry, first_path_index, first_path_snr, first_path_ns);
   217	                printf("                   peak_path_index=%u, peak_path_snr=%u, peak_path_ns=%u\n",
   218	                       peak_path_index, peak_path_snr, peak_path_ns);
   219	                printf("                   first_path_sample_offset=%u, samples_number=%u, sample_window_len=%u\n",
   220	                       first_path_sample_offset, samples_number, sample_window_len);
   221	
   222	                if (offset + sample_window_len > length) {
   223	                    printf("          WARNING: CIR sample window truncated (expected %u bytes, have %u).\n",
   224	                           sample_window_len, (unsigned int)(length - offset));
   225	                    break;
   226	                }
   227	
   228	                unsigned short preview = sample_window_len < 16 ? sample_window_len : 16;
   229	                printf("                   Sample window preview: ");
   230	                for (unsigned short i = 0; i < preview; i++) {
   231	                    printf("%02X ", value[offset + i]);
   232	                }
   233	                if (sample_window_len > preview) {
   234	                    printf("... (+%u bytes)", sample_window_len - preview);
   235	                }
   236	                printf("\n");
   237	
   238	                offset += sample_window_len;
   239	            }
   240	            if (offset < length) {
   241	                printf("          %u trailing bytes remain after CIR parsing.\n", (unsigned int)(length - offset));
   242	            }
   243	            break;
   244	        }
   245	        case FRAME_REPORT_TLV_SEGMENT_METRICS: {
   246	            unsigned short offset = 0;
   247	            unsigned int metric_index = 0;
   248	            const unsigned short entry_size = 17;
   249	
   250	            while (offset + entry_size <= length) {
   251	                unsigned char ras = value[offset++];
   252	                unsigned char segment_id = ras & 0x07;
   253	                unsigned char receiver_is_controller = (ras >> 3) & 0x01;
   254	                unsigned char receiver_id = (ras >> 4) & 0x0F;
   255	
   256	                int16_t rf_noise_floor_raw = (int16_t)read_u16_le(&value[offset]);
   257	                offset += 2;
   258	                int16_t segment_rsl_raw = (int16_t)read_u16_le(&value[offset]);
   259	                offset += 2;
   260	
   261	                uint16_t first_path_index = read_u16_le(&value[offset]);
   262	                offset += 2;
   263	                int16_t first_path_rsl_raw = (int16_t)read_u16_le(&value[offset]);
   264	                offset += 2;
   265	                int16_t first_path_time_raw = (int16_t)read_u16_le(&value[offset]);
   266	                offset += 2;
   267	
   268	                uint16_t peak_path_index = read_u16_le(&value[offset]);
   269	                offset += 2;
   270	                int16_t peak_path_rsl_raw = (int16_t)read_u16_le(&value[offset]);
   271	                offset += 2;
   272	                int16_t peak_path_time_raw = (int16_t)read_u16_le(&value[offset]);
   273	                offset += 2;
   274	
   275	                printf("          Segment Metrics %u:\n", metric_index++);
   276	                printf("            Segment: %s (ID=%u)\n", get_segment_id_name(segment_id), segment_id);
   277	                printf("            Receiver: %s (ID=%u)\n",
   278	                       receiver_is_controller ? "Controller" : "Controlee",
   279	                       receiver_id);
   280	                printf("            RF Noise Floor: %.2f dBm (raw 0x%04X)\n",
   281	                       q8_8_to_double(rf_noise_floor_raw), (unsigned int)(uint16_t)rf_noise_floor_raw);
   282	                printf("            Segment RSL: %.2f dBm (raw 0x%04X)\n",
   283	                       q8_8_to_double(segment_rsl_raw), (unsigned int)(uint16_t)segment_rsl_raw);
   284	                printf("            First Path -> index=%u, RSL=%.2f dBm, time=%.3f ns\n",
   285	                       first_path_index,
   286	                       q8_8_to_double(first_path_rsl_raw),
   287	                       q6_9_to_double(first_path_time_raw));
   288	                printf("            Peak  Path -> index=%u, RSL=%.2f dBm, time=%.3f ns\n",
   289	                       peak_path_index,
   290	                       q8_8_to_double(peak_path_rsl_raw),
   291	                       q6_9_to_double(peak_path_time_raw));
   292	            }
   293	
   294	            if (offset < length) {
   295	                printf("          WARNING: %u trailing bytes remain after parsing segment metrics.\n",
   296	                       (unsigned int)(length - offset));
   297	            }
   298	            break;
   299	        }
   300	        default: {
   301	            printf("          Raw bytes: ");
   302	            unsigned short preview = length < 32 ? length : 32;
   303	            for (unsigned short i = 0; i < preview; i++) {
   304	                printf("%02X ", value[i]);
   305	            }
   306	            if (length > preview) {
   307	                printf("... (+%u bytes)", length - preview);
   308	            }
   309	            printf("\n");
   310	            break;
   311	        }
   312	    }
   313	}
   314	
   315	void decode_session_data_credit_ntf(unsigned char* payload, int payload_len) {
   316	    printf("    SESSION_DATA_CREDIT_NTF - Data Credit Notification\n");
   317	
   318	    if (payload_len < 5) {
   319	        printf("      ERROR: Payload too short (%d bytes, need at least 5)\n", payload_len);
   320	        return;
   321	    }
   322	
   323	    unsigned int session_token = read_u32_le(payload);
   324	    unsigned char credit_availability = payload[4];
   325	
   326	    printf("      Session Token: 0x%08X\n", session_token);
   327	    printf("      Credit Availability: 0x%02X", credit_availability);
   328	    if (credit_availability == 0x00) {
   329	        printf(" (NOT_AVAILABLE)\n");
   330	    } else {
   331	        printf(" (AVAILABLE)\n");
   332	    }
   333	}
   334	
   335	void decode_session_data_transfer_status_ntf(unsigned char* payload, int payload_len) {
   336	    printf("    SESSION_DATA_TRANSFER_STATUS_NTF - Data Transfer Status Notification\n");
   337	
   338	    if (payload_len < 6) {
   339	        printf("      ERROR: Payload too short (%d bytes, need at least 6)\n", payload_len);
   340	        return;
   341	    }
   342	
   343	    unsigned int session_token = read_u32_le(payload);
   344	    unsigned short uci_sequence_number = read_u16_le(&payload[4]);
   345	
   346	    printf("      Session Token: 0x%08X\n", session_token);
   347	    printf("      UCI Sequence Number: %u\n", uci_sequence_number);
   348	
   349	    if (payload_len >= 8) {
   350	        unsigned char status = payload[6];
   351	        unsigned char tx_count = payload[7];
   352	
   353	        uci_print_data_transfer_status_line("Status", status);
   354	
   355	        printf("      TX Count: %d\n", tx_count);
   356	    }
   357	
   358	    if (payload_len > 8) {
   359	        printf("      Additional Data (%d bytes): ", payload_len - 8);
   360	        for (int i = 8; i < payload_len; i++) {
   361	            printf("%02X ", payload[i]);
   362	        }
   363	        printf("\n");
   364	    }
   365	}
