-                           lpm ? "ON" : "OFF", lpm);
-                }
-            } else {
-                printf("        Value: TRUNCATED (expected %d bytes, only %d available)\n", cfg_len, payload_len - offset);
-            }
-
-            offset += cfg_len;
-        }
-    }
-}
