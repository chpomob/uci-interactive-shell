-                case DEVICE_STATE: printf(" (DEVICE_STATE)\n"); break;
-                case LOW_POWER_MODE: printf(" (LOW_POWER_MODE)\n"); break;
-                default: printf(" (UNKNOWN)\n"); break;
-            }
-
-            uci_print_status_line("Status", cfg_status);
-        }
-    }
-}
