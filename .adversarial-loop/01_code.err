   384	    printf("      MAC Version: 0x%04X\n", mac_version);
   385	    printf("      PHY Version: 0x%04X\n", phy_version);
   386	    printf("      UCI Test Version: 0x%04X\n", uci_test_version);
   387	
   388	    if (payload_len > 9) {
   389	        printf("      Vendor Specific Info (%d bytes): ", payload_len - 9);
   390	        for (int i = 9; i < payload_len; i++) {
   391	            printf("%02X ", payload[i]);
   392	        }
   393	        printf("\n");
   394	    }
   395	}
   396	
   397	void decode_core_get_caps_info_rsp(unsigned char* payload, int payload_len) {
   398	    printf("    CORE_GET_CAPS_INFO_RSP - Get Capabilities Information Response\n");
   399	
   400	    if (payload_len < 2) {
   401	        printf("      ERROR: Payload too short (%d bytes, need at least 2)\n", payload_len);
   402	        return;
   403	    }
   404	
   405	    unsigned char status = payload[0];
   406	    unsigned char num_tlvs = payload[1];
   407	
   408	    uci_print_status_line("Status", status);
   409	
   410	    printf("      Number of TLVs: %d\n", num_tlvs);
   411	
   412	    if (num_tlvs > 0 && payload_len >= 2) {
   413	        int offset = 2;
   414	        for (int i = 0; i < num_tlvs && offset + 3 <= payload_len; i++) {
   415	            CapTlvType tlv_type = (CapTlvType)payload[offset];
   416	            unsigned char tlv_len = payload[offset + 1];
   417	            offset += 2;
   418	
   419	            printf("      TLV %d:\n", i);
   420	            printf("        Type: 0x%02X", tlv_type);
   421	            switch (tlv_type) {
   422	                case SUPPORTED_V1_FIRA_PHY_VERSION_RANGE_V2_MAX_MESSAGE_SIZE: printf(" (PHY_VERSION_RANGE)\n"); break;
   423	                case SUPPORTED_V1_FIRA_MAC_VERSION_RANGE_V2_MAX_DATA_PAYLOAD_SIZE: printf(" (MAC_VERSION_RANGE)\n"); break;
   424	                case SUPPORTED_V1_DEVICE_ROLES_V2_FIRA_PHY_VERSION_RANGE: printf(" (DEVICE_ROLES)\n"); break;
   425	                case SUPPORTED_V1_RANGING_METHOD_V2_FIRA_MAC_VERSION_RANGE: printf(" (RANGING_METHOD)\n"); break;
   426	                case SUPPORTED_V1_STS_CONFIG_V2_DEVICE_TYPE: printf(" (STS_CONFIG)\n"); break;
   427	                case SUPPORTED_V1_MULTI_NODE_MODES_V2_DEVICE_ROLES: printf(" (MULTI_NODE_MODES)\n"); break;
   428	                case SUPPORTED_V1_RANGING_TIME_STRUCT_V2_RANGING_METHOD: printf(" (RANGING_TIME_STRUCT)\n"); break;
   429	                case SUPPORTED_V1_SCHEDULED_MODE_V2_STS_CONFIG: printf(" (SCHEDULED_MODE)\n"); break;
   430	                case SUPPORTED_V1_HOPPING_MODE_V2_MULTI_NODE_MODE: printf(" (HOPPING_MODE)\n"); break;
   431	                case SUPPORTED_V1_BLOCK_STRIDING_V2_RANGING_TIME_STRUCT: printf(" (BLOCK_STRIDING)\n"); break;
   432	                case SUPPORTED_V1_UWB_INITIATION_TIME_V2_SCHEDULE_MODE: printf(" (UWB_INITIATION_TIME)\n"); break;
   433	                case SUPPORTED_V1_CHANNELS_V2_HOPPING_MODE: printf(" (CHANNELS)\n"); break;
   434	                case SUPPORTED_V1_RFRAME_CONFIG_V2_BLOCK_STRIDING: printf(" (RFRAME_CONFIG)\n"); break;
   435	                case SUPPORTED_V1_CC_CONSTRAINT_LENGTH_V2_UWB_INITIATION_TIME: printf(" (CC_CONSTRAINT_LENGTH)\n"); break;
   436	                case SUPPORTED_V1_BPRF_PARAMETER_SETS_V2_CHANNELS: printf(" (BPRF_PARAMETER_SETS)\n"); break;
   437	                case SUPPORTED_V1_HPRF_PARAMETER_SETS_V2_RFRAME_CONFIG: printf(" (HPRF_PARAMETER_SETS)\n"); break;
   438	                case SUPPORTED_V1_AOA_V2_AOA_SUPPORT: printf(" (AOA)\n"); break;
   439	                case SUPPORTED_V1_EXTENDED_MAC_ADDRESS_V2_EXTENDED_MAC_ADDRESS: printf(" (EXTENDED_MAC_ADDRESS)\n"); break;
   440	                case SUPPORTED_V1_MAX_MESSAGE_SIZE_V2_ASSIGNED: printf(" (MAX_MESSAGE_SIZE)\n"); break;
   441	                case SUPPORTED_V1_MAX_DATA_PACKET_PAYLOAD_SIZE_V2_SESSION_KEY_LENGTH: printf(" (MAX_DATA_PACKET_PAYLOAD_SIZE)\n"); break;
   442	                case SUPPORTED_V2_EXTENDED_MAC_ADDRESS: printf(" (V2_EXTENDED_MAC_ADDRESS)\n"); break;
   443	                case SUPPORTED_V2_ASSIGNED: printf(" (V2_ASSIGNED)\n"); break;
   444	                case SUPPORTED_V2_SESSION_KEY_LENGTH: printf(" (V2_SESSION_KEY_LENGTH)\n"); break;
   445	                case SUPPORTED_V2_DT_ANCHOR_MAX_ACTIVE_RR: printf(" (DT_ANCHOR_MAX_ACTIVE_RR)\n"); break;
   446	                case SUPPORTED_V2_DT_TAG_MAX_ACTIVE_RR: printf(" (DT_TAG_MAX_ACTIVE_RR)\n"); break;
   447	                case SUPPORTED_V2_DT_TAG_BLOCK_SHIPPING: printf(" (DT_TAG_BLOCK_SHIPPING)\n"); break;
   448	                case SUPPORTED_V2_PSDU_LENGTH_SUPPORT: printf(" (PSDU_LENGTH_SUPPORT)\n"); break;
   449	                case CCC_SUPPORTED_CHAPS_PER_SLOT: printf(" (CCC_CHAPS_PER_SLOT)\n"); break;
   450	                case CCC_SUPPORTED_SYNC_CODES: printf(" (CCC_SYNC_CODES)\n"); break;
   451	                case CCC_SUPPORTED_HOPPING_CONFIG_MODES_AND_SEQUENCES: printf(" (CCC_HOPPING_CONFIGS)\n"); break;
   452	                case CCC_SUPPORTED_CHANNELS: printf(" (CCC_CHANNELS)\n"); break;
   453	                case CCC_SUPPORTED_VERSIONS: printf(" (CCC_VERSIONS)\n"); break;
   454	                case CCC_SUPPORTED_UWB_CONFIGS: printf(" (CCC_UWB_CONFIGS)\n"); break;
   455	                case CCC_SUPPORTED_PULSE_SHAPE_COMBOS: printf(" (CCC_PULSE_SHAPES)\n"); break;
   456	                case CCC_SUPPORTED_RAN_MULTIPLIER: printf(" (CCC_RAN_MULTIPLIER)\n"); break;
   457	                case CCC_SUPPORTED_MAX_RANGING_SESSION_NUMBER: printf(" (CCC_MAX_RANGING_SESSIONS)\n"); break;
   458	                case CCC_SUPPORTED_MIN_UWB_INITIATION_TIME_MS: printf(" (CCC_MIN_INIT_TIME_MS)\n"); break;
   459	                case CCC_PRIORITIZED_CHANNEL_LIST: printf(" (CCC_PRIORITY_CHANNELS)\n"); break;
   460	                case CCC_SUPPORTED_UWBS_MAX_PPM: printf(" (CCC_MAX_PPM)\n"); break;
   461	                case ALIRO_SUPPORTED_MAC_MODES: printf(" (ALIRO_MAC_MODES)\n"); break;
   462	                case RADAR_SUPPORT: printf(" (RADAR_SUPPORT)\n"); break;
   463	                case SUPPORTED_POWER_STATS: printf(" (POWER_STATS)\n"); break;
   464	                case SUPPORTED_AOA_RESULT_REQ_ANTENNA_INTERLEAVING: printf(" (AOA_REQ_ANTENNA_INTERLEAVE)\n"); break;
   465	                case SUPPORTED_MIN_RANGING_INTERVAL_MS: printf(" (MIN_RANGING_INTERVAL_MS)\n"); break;
   466	                case SUPPORTED_RANGE_DATA_NTF_CONFIG: printf(" (RANGE_DATA_NTF_CONFIG)\n"); break;
   467	                case SUPPORTED_RSSI_REPORTING: printf(" (RSSI_REPORTING)\n"); break;
   468	                case SUPPORTED_DIAGNOSTICS: printf(" (DIAGNOSTICS_SUPPORT)\n"); break;
   469	                case SUPPORTED_MIN_SLOT_DURATION_RSTU: printf(" (MIN_SLOT_DURATION_RSTU)\n"); break;
   470	                case SUPPORTED_MAX_RANGING_SESSION_NUMBER: printf(" (MAX_RANGING_SESSIONS)\n"); break;
   471	                default: printf(" (UNKNOWN)\n"); break;
   472	            }
   473	
   474	            printf("        Length: %d\n", tlv_len);
   475	
   476	            if (offset + tlv_len <= payload_len) {
   477	                printf("        Value: ");
   478	                for (int j = 0; j < tlv_len; j++) {
   479	                    printf("%02X ", payload[offset + j]);
   480	                }
   481	                printf("\n");
   482	            } else {
   483	                printf("        Value: TRUNCATED (expected %d bytes, only %d available)\n", tlv_len, payload_len - offset);
   484	            }
   485	
   486	            offset += tlv_len;
   487	        }
   488	    }
   489	}
