  3255	// Decode ANDROID_RADAR_SET_APP_CONFIG response
  3256	void ui_decode_android_radar_set_app_config_rsp(const unsigned char* payload, int payload_len) {
  3257	    if (ui_color_enabled) {
  3258	        printf("  %s%sANDROID_RADAR_SET_APP_CONFIG Response:%s\n", ANSI_COLOR_BRIGHT_MAGENTA, ANSI_BOLD, ANSI_RESET);
  3259	    } else {
  3260	        printf("  ANDROID_RADAR_SET_APP_CONFIG Response:\n");
  3261	    }
  3262	
  3263	    if (payload_len < 2) {
  3264	        if (ui_color_enabled) {
  3265	            printf("    %s%sError: Payload too short (%d bytes, need at least 2)%s\n",
  3266	                   ANSI_COLOR_RED, ANSI_BOLD, payload_len, ANSI_RESET);
  3267	        } else {
  3268	            printf("    Error: Payload too short (%d bytes, need at least 2)\n", payload_len);
  3269	        }
  3270	        return;
  3271	    }
  3272	
  3273	    unsigned char status = payload[0];
  3274	    unsigned char num_configs = payload[1];
  3275	
  3276	    if (ui_color_enabled) {
  3277	        printf("    %s%sStatus:%s 0x%02X", ANSI_COLOR_BRIGHT_YELLOW, ANSI_BOLD, ANSI_RESET, status);
  3278	        switch(status) {
  3279	            case UCI_STATUS_OK: printf(" %s(OK)%s\n", ANSI_COLOR_BRIGHT_GREEN, ANSI_RESET); break;
  3280	            case UCI_STATUS_REJECTED: printf(" %s(REJECTED)%s\n", ANSI_COLOR_RED, ANSI_RESET); break;
  3281	            case UCI_STATUS_FAILED: printf(" %s(FAILED)%s\n", ANSI_COLOR_RED, ANSI_RESET); break;
  3282	            case UCI_STATUS_INVALID_PARAM: printf(" %s(INVALID_PARAM)%s\n", ANSI_COLOR_RED, ANSI_RESET); break;
  3283	            default: printf(" %s(UNKNOWN)%s\n", ANSI_COLOR_YELLOW, ANSI_RESET); break;
  3284	        }
  3285	        // Call enhanced analysis for more detailed information
  3286	        if (status != UCI_STATUS_OK) {
  3287	            enhanced_error_analysis(status);
  3288	        }
  3289	        printf("    %s%sNumber of Config Status:%s %d\n",
  3290	               ANSI_COLOR_BRIGHT_CYAN, ANSI_BOLD, ANSI_RESET, num_configs);
  3291	    } else {
  3292	        printf("    Status: 0x%02X", status);
  3293	        switch(status) {
  3294	            case UCI_STATUS_OK: printf(" (OK)\n"); break;
  3295	            case UCI_STATUS_REJECTED: printf(" (REJECTED)\n"); break;
  3296	            case UCI_STATUS_FAILED: printf(" (FAILED)\n"); break;
  3297	            case UCI_STATUS_INVALID_PARAM: printf(" (INVALID_PARAM)\n"); break;
  3298	            default: printf(" (UNKNOWN)\n"); break;
  3299	        }
  3300	        // Call enhanced analysis for more detailed information
  3301	        if (status != UCI_STATUS_OK) {
  3302	            enhanced_error_analysis(status);
  3303	        }
  3304	        printf("    Number of Config Status: %d\n", num_configs);
  3305	    }
  3306	
  3307	    // Parse config status entries (each is 2 bytes: config_id + status)
