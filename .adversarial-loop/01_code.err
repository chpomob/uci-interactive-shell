        SECURE_RANGING_NEFA_LEVEL, 0x01, 0x02,
        SECURE_RANGING_CSW_LENGTH, 0x01, 0x03,
        APPLICATION_DATA_ENDPOINT, 0x01, 0x01,
        OWR_AOA_MEASUREMENT_NTF_PERIOD, 0x01, 0x0A
