-        printf(" (%s)", name);
-    } else {
-        printf(" (UNKNOWN)");
-    }
-    printf(", Length: %u\n", length);
-
-    if (!value || length == 0) {
-        printf("          No data.\n");
-        return;
-    }
-
-    switch (tlv_type) {
-        case FRAME_REPORT_TLV_RSSI: {
-            printf("          RSSI Samples (dBm): ");
