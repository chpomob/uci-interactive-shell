-static void decode_frame_report_tlv(FrameReportTlvType tlv_type,
-                                    const unsigned char* value,
-                                    unsigned short length) {
-    const char* name = get_frame_report_tlv_name(tlv_type);
-    printf("        TLV Type: 0x%02X", tlv_type);
