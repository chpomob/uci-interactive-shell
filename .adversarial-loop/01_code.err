    81	void decode_range_vendor_data(const unsigned char* data, int length) {
    82	    if (!data || length <= 0) {
    83	        return;
    84	    }
    85	
    86	    int offset = 0;
    87	    while (offset + 6 <= length) {
    88	        unsigned char field_id = data[offset++];
    89	        unsigned char sub_id = data[offset++];
    90	        unsigned int value = read_u32_be(&data[offset]);
    91	        offset += 4;
    92	
    93	        printf("    Vendor Field 0x%02X/0x%02X: 0x%08X", field_id, sub_id, value);
    94	        if (field_id == 0x01 && sub_id == 0x01) {
    95	            printf(" (Distance: %u cm)", value);
    96	        }
    97	        printf("\n");
    98	
    99	        /* Remaining vendor bytes after the first known TLV are often zeroed out. */
   100	        int remaining = length - offset;
   101	        int all_zero = 1;
   102	        for (int i = 0; i < remaining; i++) {
   103	            if (data[offset + i] != 0x00) {
   104	                all_zero = 0;
   105	                break;
   106	            }
   107	        }
   108	        if (all_zero) {
   109	            return;
   110	        }
   111	    }
   112	
   113	    if (offset < length) {
   114	        printf("    Unparsed Vendor Data (%d bytes): ", length - offset);
   115	        for (int i = offset; i < length; i++) {
   116	            printf("%02X ", data[i]);
   117	        }
   118	        printf("\n");
   119	    }
   120	}
