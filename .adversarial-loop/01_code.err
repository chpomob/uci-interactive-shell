   663	void decode_session_set_app_config_rsp(unsigned char* payload, int payload_len) {
   664	    printf("    SESSION_SET_APP_CONFIG_RSP - Set Application Configuration Response\n");
   665	
   666	    if (payload_len < 2) {
   667	        printf("      ERROR: Payload too short (%d bytes, need at least 2)\n", payload_len);
   668	        return;
   669	    }
   670	
   671	    unsigned char status = payload[0];
   672	    unsigned char num_configs = payload[1];
   673	
   674	    uci_print_status_line("Status", status);
   675	
   676	    printf("      Number of Config Status: %d\n", num_configs);
   677	
   678	    if (num_configs > 0 && payload_len >= 2) {
   679	        int offset = 2;
   680	        for (int i = 0; i < num_configs && offset + 2 <= payload_len; i++) {
   681	            AppConfigTlvType cfg_id = (AppConfigTlvType)payload[offset];
   682	            unsigned char cfg_status = payload[offset + 1];
   683	            const char* cfg_name = uci_config_get_app_param_name(cfg_id);
   684	            offset += 2;
   685	
   686	            printf("      Config %d:\n", i);
   687	            printf("        Config ID: 0x%02X", cfg_id);
   688	            printf(" (%s)\n", cfg_name ? cfg_name : "UNKNOWN");
   689	
   690	            uci_print_status_line("Status", cfg_status);
   691	        }
   692	    }
   693	}
   694	
   695	void decode_session_get_app_config_rsp(unsigned char* payload, int payload_len) {
   696	    printf("    SESSION_GET_APP_CONFIG_RSP - Get Application Configuration Response\n");
   697	
   698	    if (payload_len < 2) {
   699	        printf("      ERROR: Payload too short (%d bytes, need at least 2)\n", payload_len);
   700	        return;
   701	    }
   702	
   703	    unsigned char status = payload[0];
   704	    unsigned char num_tlvs = payload[1];
   705	
   706	    uci_print_status_line("Status", status);
   707	
   708	    printf("      Number of TLVs: %d\n", num_tlvs);
   709	
   710	    if (num_tlvs > 0 && payload_len >= 2) {
   711	        int offset = 2;
   712	        for (int i = 0; i < num_tlvs && offset + 3 <= payload_len; i++) {
   713	            AppConfigTlvType cfg_id = (AppConfigTlvType)payload[offset];
   714	            unsigned char cfg_len = payload[offset + 1];
   715	            const char* cfg_name = uci_config_get_app_param_name(cfg_id);
   716	            offset += 2;
   717	
   718	            printf("      TLV %d:\n", i);
   719	            printf("        Config ID: 0x%02X", cfg_id);
   720	            printf(" (%s)\n", cfg_name ? cfg_name : "UNKNOWN");
   721	            printf("        Length: %d\n", cfg_len);
   722	
   723	            if (offset + cfg_len <= payload_len) {
   724	                printf("        Value: ");
   725	                for (int j = 0; j < cfg_len; j++) {
   726	                    printf("%02X ", payload[offset + j]);
   727	                }
   728	                printf("\n");
   729	            } else {
   730	                printf("        Value: TRUNCATED (expected %d bytes, only %d available)\n", cfg_len, payload_len - offset);
   731	            }
   732	
   733	            offset += cfg_len;
   734	        }
   735	    }
   736	}
   737	
   738	void decode_range_data_ntf(unsigned char* payload, int payload_len) {
   739	    printf("    RANGE_DATA_NTF - Range Data Notification\n");
   740	
   741	    if (payload_len < 12) {
   742	        printf("      ERROR: Payload too short (%d bytes, need at least 12)\n", payload_len);
   743	        return;
   744	    }
   745	
   746	    unsigned int session_token = read_u32_le(&payload[0]);
   747	    unsigned int sequence_number = read_u32_le(&payload[4]);
   748	    unsigned int control_word = read_u32_le(&payload[8]);
   749	
   750	    unsigned char status = control_word & 0xFF;
   751	    unsigned char mac_indicator = (control_word >> 8) & 0xFF;
   752	    unsigned char measurement_count = (control_word >> 16) & 0xFF;
   753	    unsigned char vendor_flags = (control_word >> 24) & 0xFF;
   754	
   755	    printf("      Session Token: 0x%08X\n", session_token);
   756	    printf("      Sequence Number: %u\n", sequence_number);
   757	    uci_print_status_line("Status", status);
   758	    printf("      MAC Indicator: 0x%02X (%s)\n",
   759	           mac_indicator, mac_indicator ? "EXTENDED_ADDRESS" : "SHORT_ADDRESS");
   760	    printf("      Measurement Count: %u\n", measurement_count);
   761	    if (vendor_flags) {
   762	        printf("      Vendor Flags: 0x%02X\n", vendor_flags);
   763	    }
   764	
   765	    int offset = 12;
   766	    for (unsigned int i = 0; i < measurement_count; i++) {
   767	        printf("      Measurement %u:\n", i + 1);
   768	        if (mac_indicator == 0) {
   769	            if (offset + 20 > payload_len) {
   770	                printf("        WARNING: Incomplete short-address measurement (need 20 bytes, have %d).\n",
   771	                       payload_len - offset);
   772	                return;
   773	            }
   774	            print_short_address_measurement(&payload[offset]);
   775	            offset += 20;
   776	        } else {
   777	            if (offset + 26 > payload_len) {
   778	                printf("        WARNING: Incomplete extended-address measurement (need 26 bytes, have %d).\n",
   779	                       payload_len - offset);
   780	                return;
   781	            }
   782	            print_extended_address_measurement(&payload[offset]);
   783	            offset += 26;
   784	        }
   785	    }
   786	
   787	    if (offset < payload_len) {
   788	        printf("      Vendor-specific Range Data (%d bytes):\n", payload_len - offset);
   789	        decode_range_vendor_data(&payload[offset], payload_len - offset);
   790	    }
   791	}
   792	
   793	void decode_android_range_diagnostics_ntf(unsigned char* payload, int payload_len) {
   794	    printf("    ANDROID_FIRA_RANGE_DIAGNOSTICS_NTF - Range Diagnostics Notification\n");
   795	
   796	    if (payload_len < 9) {
   797	        printf("      ERROR: Payload too short (%d bytes, need at least 9)\n", payload_len);
   798	        return;
   799	    }
   800	
   801	    uint32_t session_token = read_u32_le(&payload[0]);
   802	    uint32_t sequence_number = read_u32_le(&payload[4]);
   803	    unsigned char report_count = payload[8];
   804	
   805	    printf("      Session Token: 0x%08X\n", session_token);
   806	    printf("      Sequence Number: %u\n", sequence_number);
   807	    printf("      Frame Reports: %u\n", report_count);
   808	
   809	    int offset = 9;
   810	    for (unsigned char report_idx = 0; report_idx < report_count; report_idx++) {
   811	        if (offset + 4 > payload_len) {
   812	            printf("      WARNING: Incomplete frame report header at index %u (need 4 bytes, have %d).\n",
   813	                   report_idx, payload_len - offset);
   814	            return;
   815	        }
   816	
   817	        unsigned char uwb_msg_id = payload[offset];
   818	        unsigned char action = payload[offset + 1];
   819	        unsigned char antenna_set = payload[offset + 2];
   820	        unsigned char tlv_count = payload[offset + 3];
   821	        offset += 4;
   822	
   823	        printf("      Frame Report %u:\n", report_idx);
   824	        printf("        UWB Message ID: 0x%02X\n", uwb_msg_id);
   825	        printf("        Action: 0x%02X\n", action);
   826	        printf("        Antenna Set: 0x%02X\n", antenna_set);
   827	        printf("        TLV Count: %u\n", tlv_count);
   828	
   829	        for (unsigned char tlv_idx = 0; tlv_idx < tlv_count; tlv_idx++) {
   830	            if (offset + 3 > payload_len) {
   831	                printf("        WARNING: Incomplete frame report TLV header at index %u (need 3 bytes, have %d).\n",
   832	                       tlv_idx, payload_len - offset);
   833	                return;
   834	            }
   835	
   836	            FrameReportTlvType tlv_type = (FrameReportTlvType)payload[offset];
   837	            unsigned short tlv_len = read_u16_le(&payload[offset + 1]);
   838	            offset += 3;
   839	
   840	            if (offset + tlv_len > payload_len) {
   841	                printf("        WARNING: TLV 0x%02X length %u exceeds remaining payload (%d).\n",
   842	                       tlv_type, tlv_len, payload_len - offset);
   843	                return;
   844	            }
   845	
   846	            decode_frame_report_tlv(tlv_type, &payload[offset], tlv_len);
   847	            offset += tlv_len;
   848	        }
   849	    }
   850	
   851	    if (offset < payload_len) {
   852	        printf("      NOTE: %d trailing diagnostic bytes remain after parsing.\n", payload_len - offset);
   853	    }
   854	}
