import re, pathlib
root=pathlib.Path('.')
files=[p for p in list((root/'src').glob('*.c'))+list((root/'tests').glob('*.c'))+list((root/'include').glob('*.h')) if p.is_file()]
for target in ['src/uci_plain_decoders.c','src/uci_ui_packet_decoder.c','src/uci_ui_range_decoder.c']:
    text=pathlib.Path(target).read_text()
    names=[]
    for m in re.finditer(r'"'^(?!static'"\\b)[\\w\\s\\*]+\\b((?:ui_)?decode_[A-Za-z0-9_]+)\\s*\\(["'^;]*'"\\)\\s*\\{', text, re.M):
        names.append(m.group(1))
    print('\\n##', target)
    for name in names:
        refs=[]
        pat=re.compile(r'\\b'+re.escape(name)+r'\\s*\\(')
        for p in files:
            t=p.read_text(errors='ignore')
            for i,line in enumerate(t.splitlines(),1):
                if not pat.search(line): continue
                # skip definition in same target
                if str(p)==target and '{' in line: continue
                # skip declarations
                if line.strip().endswith(';') and (str(p).startswith('include/') or line.lstrip().startswith('void ')):
                    refs.append((str(p),i,line.strip(),'decl'))
                else:
                    refs.append((str(p),i,line.strip(),'call'))
        calls=[r for r in refs if r[3]=='call']
        print(f'{name}: calls={len(calls)}')
        for r in calls[:8]: print('  ',r[0],r[1],r[2])
