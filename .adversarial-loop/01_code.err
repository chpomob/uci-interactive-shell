   635	
   636	void decode_session_init_rsp(unsigned char* payload, int payload_len) {
   637	    printf("    SESSION_INIT_RSP - Session Initialization Response\n");
   638	
   639	    if (payload_len < 5) {
   640	        printf("      ERROR: Payload too short (%d bytes, need at least 5)\n", payload_len);
   641	        return;
   642	    }
   643	
