-    if (credit_availability == 0x00) {
-        printf(" (NOT_AVAILABLE)\n");
-    } else {
-        printf(" (AVAILABLE)\n");
-    }
-}
-
-void decode_session_data_transfer_status_ntf(unsigned char* payload, int payload_len) {
