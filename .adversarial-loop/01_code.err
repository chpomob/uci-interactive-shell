   367	void decode_core_device_info_rsp(unsigned char* payload, int payload_len) {
   368	    printf("    CORE_DEVICE_INFO_RSP - Device Information Response\n");
   369	
   370	    if (payload_len < 9) {
   371	        printf("      ERROR: Payload too short (%d bytes, need at least 9)\n", payload_len);
   372	        return;
   373	    }
   374	
   375	    unsigned char status = payload[0];
   376	    unsigned short uci_version = read_u16_le(&payload[1]);
   377	    unsigned short mac_version = read_u16_le(&payload[3]);
   378	    unsigned short phy_version = read_u16_le(&payload[5]);
   379	    unsigned short uci_test_version = read_u16_le(&payload[7]);
