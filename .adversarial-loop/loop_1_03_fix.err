@@ -344,6 +357,32 @@
     test_case_end_table_driven_dispatch:;
 #undef test_case_end
 
+#define test_case_end test_case_end_session_status_ui_decoder_smoke
+    TEST_CASE(session_status_ui_decoder_smoke);
