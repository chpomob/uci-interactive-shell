@@ -151,6 +152,18 @@
     ui_color_enabled = g_capture_ctx.saved_color;
 }
 
+static void emit_session_status_ui_decoder(void) {
+    static const unsigned char k_payload[] = {
+        0x78, 0x56, 0x34, 0x12,
+        SESSION_STATE_ACTIVE,
+        STATE_CHANGE_WITH_SESSION_MANAGEMENT_COMMANDS
+    };
+
+    ui_color_enabled = 0;
